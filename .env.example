# =====================================================================
# Freelandoo Backend — .env.example
# Copiar como `.env` e preencher.
# Todas as chaves listadas aqui são SERVER-ONLY (nunca expor no front).
# =====================================================================

# ─── Servidor ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── Banco de dados ───────────────────────────────────────────────────
# Em prod (Railway/Neon/Supabase) já vem com SSL; em dev local geralmente sem.
DATABASE_URL=postgresql://user:password@host:port/db?sslmode=require
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ─── Auth ─────────────────────────────────────────────────────────────
# Gerar com: `openssl rand -base64 48` (mínimo 32 bytes)
JWT_SECRET=troque_para_um_segredo_aleatorio_longo
JWT_EXPIRES_IN=1d

# Google OAuth (signin com Google) — Client ID do Google Cloud Console
GOOGLE_CLIENT_ID=

# ─── URLs ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:3001

# ─── Cloudflare R2 (bucket único compartilhado por features) ──────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_ACCOUNT_ID=

# ─── Stripe ───────────────────────────────────────────────────────────
# Chave secreta (sk_test_... em dev, sk_live_... em prod)
STRIPE_SECRET_KEY=
# Secret do endpoint de webhook (whsec_...) — diferente por ambiente
STRIPE_WEBHOOK_SECRET=

# ─── Resend (transactional email) ─────────────────────────────────────
RESEND_API_KEY=
# Remetente verificado: "Nome <email@dominio.com>"
RESEND_FROM=Freelandoo <noreply@freelandoo.com.br>

# ─── Melhor Envio — frete da Loja ─────────────────────────────────────
# MELHOR_ENVIO_ENV=production liga a API real (melhorenvio.com.br);
# ausente/qualquer outro valor = sandbox.
MELHOR_ENVIO_ENV=sandbox
# Token de PRODUÇÃO (painel melhorenvio.com.br → Integrações → Tokens).
# JWT longo; expira — rotacionar antes. Obrigatório quando ENV=production.
MELHOR_ENVIO_TOKEN=
# Token do SANDBOX (sandbox.melhorenvio.com.br). Usado quando ENV != production.
MELHOR_ENVIO_SANDBOX_TOKEN=
# Email técnico que vai no User-Agent das chamadas (exigência do ME).
MELHOR_ENVIO_CONTACT_EMAIL=alex.rodriguus@gmail.com

# ─── Lives (LiveKit) ──────────────────────────────────────────────────
# Dev LOCAL (docker --dev em live-infra/docker-compose.yml): os defaults abaixo
# já batem com o container, então pode deixar como está.
# PROD: trocar pelo host do LiveKit self-host (Hetzner) + chaves próprias.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
