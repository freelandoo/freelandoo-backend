# Servidor
PORT=3000
NODE_ENV=development

# Banco (PostgreSQL)
DATABASE_URL=postgres://user:pass@localhost:5432/creators_views
# Use true em produção quando o provedor exigir SSL (ex.: Neon, Supabase)
DATABASE_SSL=false
# Em provedores com certificado custom, pode ser necessário false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# Auth
JWT_SECRET=altere_para_um_segredo_longo
JWT_EXPIRES_IN=1d

# URLs
FRONTEND_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# Mercado Pago
MP_ACCESS_TOKEN=

# Cloudflare R2 (S3)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM=Creators Views <noreply@seudominio.com>
